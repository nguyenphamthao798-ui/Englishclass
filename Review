<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Part 3: Writing</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f7fb;
      margin: 0;
      color: #222;
    }

    header {
      background: #243b63;
      color: white;
      text-align: center;
      padding: 20px;
    }

    main {
      max-width: 1000px;
      margin: 25px auto;
      background: white;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    h2 {
      color: #243b63;
      border-bottom: 2px solid #243b63;
      padding-bottom: 6px;
      margin-top: 35px;
    }

    label {
      font-weight: bold;
    }

    input, textarea {
      width: 100%;
      padding: 10px;
      margin-top: 6px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 15px;
      box-sizing: border-box;
    }

    textarea {
      min-height: 70px;
      resize: vertical;
    }

    .student-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
      margin-bottom: 25px;
    }

    .question {
      background: #f9fbff;
      padding: 15px;
      margin: 14px 0;
      border-left: 5px solid #243b63;
      border-radius: 8px;
    }

    .answers {
      background: #eef4ff;
      padding: 10px;
      border-radius: 8px;
      margin-top: 10px;
      display: none;
      font-size: 14px;
    }

    .show-btn, .submit-btn {
      background: #243b63;
      color: white;
      padding: 10px 18px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 10px;
    }

    .show-btn:hover, .submit-btn:hover {
      background: #1a2d4d;
    }

    .button-area {
      text-align: center;
      margin-top: 30px;
    }

    footer {
      text-align: center;
      padding: 15px;
      color: #666;
      font-size: 14px;
    }
  </style>
</head>

<body>
<header>
  <h1>PART 3: WRITING</h1>
  <p>Interactive English Writing Practice</p>
</header>

<main>
<form id="writingForm">

  <section class="student-info">
    <label>Name:
      <input id="name" type="text" required placeholder="Enter your name">
    </label>

    <label>Class:
      <input id="className" type="text" required placeholder="11/___">
    </label>

    <label>Student ID:
      <input id="studentId" type="text" required placeholder="Enter your student ID">
    </label>
  </section>

  <h2>I. Rewrite each sentence using the given word</h2>

  <div id="part1"></div>

  <h2>II. Use the given words to write complete sentences</h2>

  <div id="part2"></div>

  <div class="button-area">
    <button class="submit-btn" type="submit">Submit to Teacher</button>
  </div>

</form>
</main>

<footer>
  English Writing Practice - Grade 11
</footer>

<script>
const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyhOiLiokMMvQWlgPUhMKGxIJ2eSgYjuHlGwwXZqugiuVVADnmvGFkhxz4z-3MsywFJ/exec";

const part1Questions = [
  {
    q: "Preserving cultural heritage is important. Many young people are not interested. (although)",
    a1: "Although preserving cultural heritage is important, many young people are not interested.",
    a2: "Many young people are not interested although preserving cultural heritage is important."
  },
  {
    q: "Traditional crafts are valuable. They are disappearing. (despite)",
    a1: "Despite being valuable, traditional crafts are disappearing.",
    a2: "Despite their value, traditional crafts are disappearing."
  },
  {
    q: "She wants to become a doctor. The training is very demanding. (however)",
    a1: "She wants to become a doctor. However, the training is very demanding.",
    a2: "She wants to become a doctor; however, the training is very demanding."
  },
  {
    q: "She chose a challenging career path. She wanted to follow her passion. (because)",
    a1: "She chose a challenging career path because she wanted to follow her passion.",
    a2: "Because she wanted to follow her passion, she chose a challenging career path."
  },
  {
    q: "Body shaming not only creates a negative environment for students but also affects their self-confidence. (besides)",
    a1: "Body shaming creates a negative environment for students. Besides, it affects their self-confidence.",
    a2: "Body shaming affects students' self-confidence. Besides, it creates a negative environment for them."
  },
  {
    q: "Cyberbullying can lower students' self-confidence. They may struggle with social interactions. (As a consequence)",
    a1: "Cyberbullying can lower students' self-confidence. As a consequence, they may struggle with social interactions.",
    a2: "Cyberbullying may lower students' self-confidence; as a consequence, they may struggle with social interactions."
  },
  {
    q: "While some students stand up to bullying, others remain silent for fear of the consequences. (By contrast)",
    a1: "Some students stand up to bullying. By contrast, others remain silent for fear of the consequences.",
    a2: "Some students stand up to bullying; by contrast, others remain silent for fear of the consequences."
  },
  {
    q: "Many students skip breakfast, so they have low energy levels in the morning. (Because of)",
    a1: "Because of skipping breakfast, many students have low energy levels in the morning.",
    a2: "Because of the fact that many students skip breakfast, they have low energy levels in the morning."
  },
  {
    q: "The school organizes environmental campaigns. It also encourages students to recycle. (In addition)",
    a1: "The school organizes environmental campaigns. In addition, it encourages students to recycle.",
    a2: "The school organizes environmental campaigns; in addition, it encourages students to recycle."
  },
  {
    q: "He feels more confident now. He has practiced speaking English regularly. (since)",
    a1: "He feels more confident now since he has practiced speaking English regularly.",
    a2: "Since he has practiced speaking English regularly, he feels more confident now."
  },
  {
    q: "Bullying has serious consequences. Schools must take stronger action. (therefore)",
    a1: "Bullying has serious consequences. Therefore, schools must take stronger action.",
    a2: "Bullying has serious consequences; therefore, schools must take stronger action."
  },
  {
    q: "As bullying is a pressing issue at school, it needs immediate action. (Because of)",
    a1: "Because of being a pressing issue at school, bullying needs immediate action.",
    a2: "Because of the pressing issue of bullying at school, it needs immediate action."
  },
  {
    q: "Although we faced many difficulties, we successfully ran an anti-bullying campaign. (In spite of)",
    a1: "In spite of facing many difficulties, we successfully ran an anti-bullying campaign.",
    a2: "In spite of many difficulties, we successfully ran an anti-bullying campaign."
  },
  {
    q: "Minh asked Hung to skip class to go to the park but Hung did not agree. (however)",
    a1: "Minh asked Hung to skip class to go to the park. However, Hung did not agree.",
    a2: "Minh asked Hung to skip class to go to the park; however, Hung did not agree."
  },
  {
    q: "She is highly skilled in communication. She has strong leadership abilities. (Moreover)",
    a1: "She is highly skilled in communication. Moreover, she has strong leadership abilities.",
    a2: "She is highly skilled in communication; moreover, she has strong leadership abilities."
  }
];

const part2Questions = [
  {
    q: "Young people / take part / cultural activities / promote / preserve / national heritage.",
    a1: "Young people should take part in cultural activities to promote and preserve national heritage.",
    a2: "Young people take part in cultural activities to promote and preserve national heritage."
  },
  {
    q: "Have / finish / university, / she / decide / live independently.",
    a1: "Having finished university, she decided to live independently.",
    a2: "After having finished university, she decided to live independently."
  },
  {
    q: "It / be / young people / play / important role / preserving heritage.",
    a1: "It is young people who play an important role in preserving heritage.",
    a2: "It is young people that play an important role in preserving heritage."
  },
  {
    q: "Although / ecosystem / be fragile, / humans / continue / exploit it.",
    a1: "Although the ecosystem is fragile, humans continue to exploit it.",
    a2: "Although the ecosystem was fragile, humans continued to exploit it."
  },
  {
    q: "He / learn / manage money / moreover / he / develop / life skills.",
    a1: "He learns to manage money; moreover, he develops life skills.",
    a2: "He has learned to manage money. Moreover, he has developed life skills."
  },
  {
    q: "It / be / government / need / take action / reduce poverty.",
    a1: "It is the government that needs to take action to reduce poverty.",
    a2: "It is the government who needs to take action to reduce poverty."
  },
  {
    q: "She / be / only person / understand / this problem.",
    a1: "She is the only person who understands this problem.",
    a2: "She was the only person who understood this problem."
  },
  {
    q: "He / regret / have / waste / time / when he / be / young.",
    a1: "He regrets having wasted time when he was young.",
    a2: "He regretted having wasted time when he was young."
  },
  {
    q: "They / deny / have / damage / the environment / the past.",
    a1: "They deny having damaged the environment in the past.",
    a2: "They denied having damaged the environment in the past."
  },
  {
    q: "In spite / face / many challenges / he / pursue / dream career.",
    a1: "In spite of facing many challenges, he pursued his dream career.",
    a2: "In spite of facing many challenges, he continues to pursue his dream career."
  },
  {
    q: "She / join / volunteer program / help / disadvantaged children.",
    a1: "She joined a volunteer program to help disadvantaged children.",
    a2: "She joins a volunteer program to help disadvantaged children."
  },
  {
    q: "Have / learn / traditions, / they / feel / more responsible / protect them.",
    a1: "Having learned about traditions, they feel more responsible for protecting them.",
    a2: "After having learned about traditions, they felt more responsible for protecting them."
  },
  {
    q: "Since / cultural heritage / be / important, / we / need / protect it.",
    a1: "Since cultural heritage is important, we need to protect it.",
    a2: "Since cultural heritage plays an important role, we need to protect it."
  },
  {
    q: "He / make / decision / move out / live independently.",
    a1: "He made a decision to move out and live independently.",
    a2: "He has made a decision to move out and live independently."
  },
  {
    q: "They / apologize / have / treat / others unfairly.",
    a1: "They apologized for having treated others unfairly.",
    a2: "They apologize for having treated others unfairly."
  }
];

function createQuestions(list, containerId, startNumber) {
  const container = document.getElementById(containerId);

  list.forEach((item, index) => {
    const number = startNumber + index;

    const div = document.createElement("div");
    div.className = "question";

    div.innerHTML = `
      <p><b>${number}.</b> ${item.q}</p>
      <textarea name="answer${number}" required placeholder="Write your answer here..."></textarea>
      <br>
      <button type="button" class="show-btn" onclick="toggleAnswer('answerBox${number}')">
        Show possible answers
      </button>
      <div class="answers" id="answerBox${number}">
        <p><b>Possible answer 1:</b> ${item.a1}</p>
        <p><b>Possible answer 2:</b> ${item.a2}</p>
      </div>
    `;

    container.appendChild(div);
  });
}

function toggleAnswer(id) {
  const box = document.getElementById(id);
  box.style.display = box.style.display === "block" ? "none" : "block";
}

createQuestions(part1Questions, "part1", 1);
createQuestions(part2Questions, "part2", 16);

document.getElementById("writingForm").addEventListener("submit", function(event) {
  event.preventDefault();

  const submitButton = document.querySelector(".submit-btn");
  submitButton.disabled = true;
  submitButton.textContent = "Submitting...";

  const answers = Array.from(document.querySelectorAll("textarea")).map(textarea => textarea.value);

  const data = {
    name: document.getElementById("name").value,
    className: document.getElementById("className").value,
    studentId: document.getElementById("studentId").value,
    answers: answers
  };

  fetch(SCRIPT_URL, {
    method: "POST",
    mode: "no-cors",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(data)
  })
  .then(() => {
    alert("Submitted successfully!");
    document.getElementById("writingForm").reset();

    document.querySelectorAll(".answers").forEach(box => {
      box.style.display = "none";
    });
  })
  .catch(() => {
    alert("Error submitting. Please try again.");
  })
  .finally(() => {
    submitButton.disabled = false;
    submitButton.textContent = "Submit to Teacher";
  });
});
</script>

</body>
</html>
